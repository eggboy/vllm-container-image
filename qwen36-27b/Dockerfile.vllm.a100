# =============================================================================
# Dockerfile.vllm.qwen36-27b.aca — Serve Qwen3.6-27B via vLLM on A100
# Target: Azure Container Apps Serverless GPU (NVIDIA A100 80GB)
#
# Qwen3.6-27B: 27B dense params, ~55 GB BF16 weights, fits 1x A100 80GB
# with ample headroom for 128K KV-cache. Apache 2.0 license.
# Native 262K context; we cap at 131072 (128K) for Copilot BYOK compatibility.
#
# A100 80GB (Consumption-GPU-NC24-A100):
#   - 80 GB HBM2e, 2 TB/s bandwidth
#   - FP8 KV-cache via software quantization — halves cache memory
#   - 24 vCPUs, 220 GiB system memory on ACA NC24-A100 profile
#   - CUDA graphs work well with dense models (no --enforce-eager needed)
#
# Qwen3.6 improvements over 3.5:
#   - Hybrid Gated DeltaNet architecture for better long-context
#   - Native reasoning/thinking mode (--reasoning-parser qwen3)
#   - Stronger agentic coding and tool-use benchmarks
#   - Multimodal support (text + image)
#
# Build via ACR Tasks:
#   az acr build --registry <ACR_NAME> \
#       --image qwen36-27b-vllm:latest \
#       --file Dockerfile.vllm.qwen36-27b.aca \
#       --timeout 7200 .
#
# Build with Hugging Face token (for gated/private models):
#   az acr build --registry <ACR_NAME> \
#       --image qwen36-27b-vllm:latest \
#       --file Dockerfile.vllm.qwen36-27b.aca \
#       --build-arg HF_TOKEN=hf_xxx \
#       --timeout 7200 .
# =============================================================================

# ---------------------------------------------------------------------------
# Stage 1: Download model weights (~55 GB BF16)
# ---------------------------------------------------------------------------
FROM python:3.12.11-slim AS model-download

ARG HF_TOKEN
ENV HF_TOKEN=${HF_TOKEN}

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

RUN uv pip install --system "huggingface_hub"

RUN hf download Qwen/Qwen3.6-27B \
        --local-dir /model/qwen36-27b

# ---------------------------------------------------------------------------
# Stage 2: vLLM runtime (A100-optimized for ACA Serverless GPU)
# ---------------------------------------------------------------------------
FROM vllm/vllm-openai:latest

LABEL org.opencontainers.image.title="Qwen3.6-27B vLLM Server (A100 ACA)" \
      org.opencontainers.image.description="Qwen3.6-27B 27B dense served via vLLM on A100 for Azure Container Apps Serverless GPU"

ENV MODEL_PATH=/model/qwen36-27b

COPY --from=model-download /model/qwen36-27b /model/qwen36-27b

EXPOSE 8000

# Health check for ACA startup probes and readiness
HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=5 \
    CMD curl -f http://localhost:8000/health || exit 1

ENTRYPOINT ["vllm", "serve"]

# ---- vLLM serving flags (A100 + ACA optimized) ----
# --gpu-memory-utilization 0.95 : Maximize 80 GB HBM2e
# --max-model-len 131072        : 128K context for Copilot BYOK (system prompt
#                                  alone can exceed 32K). Model natively supports
#                                  up to 262K.
# --kv-cache-dtype fp8           : FP8 KV-cache halves memory vs BF16, critical
#                                  for fitting 128K context. Software FP8 on A100.
# --enable-prefix-caching       : Reuse KV-cache for shared prefixes — reduces
#                                  redundant compute for repeated system prompts
# --reasoning-parser qwen3      : Enable Qwen3.6 native thinking/reasoning mode
# --tool-call-parser qwen3_coder: Qwen3.6 native tool calling format
# --max-num-seqs 8              : Limit concurrent requests to prevent memory
#                                  pressure with 128K context windows
# --served-model-name           : Explicit model name for API compatibility
# --dtype auto                   : vLLM auto-selects bfloat16
CMD [ \
    "/model/qwen36-27b", \
    "--host", "0.0.0.0", \
    "--port", "8000", \
    "--tensor-parallel-size", "1", \
    "--trust-remote-code", \
    "--gpu-memory-utilization", "0.95", \
    "--max-model-len", "131072", \
    "--dtype", "auto", \
    "--kv-cache-dtype", "fp8", \
    "--enable-prefix-caching", \
    "--enable-auto-tool-choice", \
    "--reasoning-parser", "qwen3", \
    "--tool-call-parser", "qwen3_coder", \
    "--max-num-seqs", "8", \
    "--served-model-name", "Qwen3.6-27B" \
]
